{
  "name": "verdira-workspace",
  "version": "1.0.0",
  "description": "Verdira - Personalized Carbon Footprint Companion",
  "main": "server.js",
  "scripts": {
    "install-all": "npm install && npm run install:frontend",
    "install:frontend": "npm --prefix frontend install",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server.js",
    "dev:client": "npm --prefix frontend run dev",
    "build": "npm run build:frontend",
    "build:frontend": "npm --prefix frontend run build",
    "start": "node server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  },
  "private": true
}
